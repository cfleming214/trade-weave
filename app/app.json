{
  "expo": {
    "name": "TradeWeave",
    "slug": "tradeweave",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0b0e14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cfleming.tradeweave",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "package": "com.cfleming.tradeweave",
      "usesCleartextTraffic": true
    }
  }
}
