# --- Alpaca ---
# Get keys from https://app.alpaca.markets/ (use PAPER keys to start)
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=
# true = paper trading (default, safe). false = LIVE real-money trading.
ALPACA_PAPER=true
# Safety interlock: even with ALPACA_PAPER=false and TRADING_ENABLED=true, the
# bot will NOT place real-money orders unless this is explicitly true.
CONFIRM_LIVE=false

# --- Anthropic (needed for the 'llm' engine AND the on-demand Claude analysis) ---
ANTHROPIC_API_KEY=
# Let the on-demand analysis use web search to ground its week-ahead view.
ANALYSIS_WEB_SEARCH=true

# --- Engine ---
# Decision engine mode: technical | llm
ENGINE_MODE=technical
# Master switch. If false, the bot observes/logs but never places orders.
TRADING_ENABLED=false
# Comma-separated symbols the bot is allowed to consider.
WATCHLIST=AAPL,MSFT,SPY,BTC/USD
# How often the strategy loop runs, in seconds.
LOOP_INTERVAL_SECONDS=60

# --- Risk guardrails ---
# Max fraction of equity to allocate to a single position (0.10 = 10%).
MAX_POSITION_PCT=0.10
# Stop-loss / take-profit as fractions from entry. Set TAKE_PROFIT_PCT=0 to
# disable the fixed take-profit and let winners run (exit on the strategy signal).
STOP_LOSS_PCT=0.05
TAKE_PROFIT_PCT=0.10
# Halt all new entries once daily realized+unrealized loss exceeds this fraction of equity.
MAX_DAILY_LOSS_PCT=0.03

# --- Technical strategy tuning ---
# Bar timeframe the strategy runs on (1Min, 5Min, 1Hour, 1Day). Higher
# timeframes = fewer, higher-quality signals and far less churn.
STRATEGY_TIMEFRAME=1Min
# SMA crossover periods + long-term trend MA.
STRATEGY_FAST=10
STRATEGY_SLOW=30
STRATEGY_TREND=50
STRATEGY_RSI_PERIOD=14
# Skip an entry if RSI is already this hot (crossovers fire ~70, keep this lenient).
STRATEGY_RSI_OVERBOUGHT=80
# Anti-whipsaw: min bars to hold before a crossover exit; bars to wait before
# re-entering a symbol; hysteresis band the cross must clear.
STRATEGY_MIN_HOLD_BARS=5
STRATEGY_REENTRY_BARS=5
STRATEGY_BAND=0.001
# Optional: only go long when the slow MA is rising. Off by default.
STRATEGY_TREND_FILTER=false

# --- Local server ---
PORT=4000
# Bind to localhost only by default; set 0.0.0.0 to reach it from your phone on the LAN.
HOST=127.0.0.1
