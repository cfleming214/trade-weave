{
  "name": "tradeweave-server",
  "version": "0.1.0",
  "private": true,
  "description": "TradeWeave — personal, local-first autonomous trading bot (Alpaca)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "backtest": "tsx src/backtest/run.ts",
    "analyze": "tsx src/advisor/run.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "technicalindicators": "^3.1.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
